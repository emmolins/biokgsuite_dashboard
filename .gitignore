# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Environment ───────────────────────────────────────────────────────────────
.env
.venv/
venv/
env/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.claude/

# ── Large KG data files (must be downloaded separately — see README) ──────────
data/primekg/
data/hetionet/
data/drkg/
data/matrix/
data/openbilink/
data/biokg/
data/pharmkg/
data/gold_standards/

# ── API response cache (regenerated on first run of notebooks) ───────────────
data/validation_cache.json
data/mesh_area_cache.json

# ── Generated results (reproducible by running notebooks) ────────────────────
results/figures/
results/checkpoints/
results/cache/

# ── Cowork / skill workspace (local only) ────────────────────────────────────
skills/

# ── Executed notebook copies (regenerable) ───────────────────────────────────
*_executed.ipynb

# ── Working documents (not part of the benchmark) ────────────────────────────
*.docx

# ── Backup files (manual patches, pre-restructure snapshots) ─────────────────
*.bak
*.pre_*.bak

# ── Per-notebook output dirs (regenerable working files) ─────────────────────
results/nb*/
results/.pre_*/
results/ddi_gap_audit*.json

